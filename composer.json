{
    "name": "sakoo/framework",
    "description": "The Sakoo PHP Web Framework",
    "type": "project",
    "license": "MIT",
    "keywords": ["framework", "sakoo"],
    "authors": [
        {
            "name": "Pouya Asgharnejad Tehran",
            "email": "pouyaaofficial@gmail.com",
            "role": "Software Engineer"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "php" : ">=8.1",
        "symfony/finder": "^6.0",
        "sakoo/framework-core": "dev-main"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.5",
        "phpunit/phpunit": "^9.5"
    },
    "scripts": {
        "stylecheck": "./vendor/bin/php-cs-fixer fix --dry-run",
        "test": "./vendor/bin/phpunit"
    }
}
